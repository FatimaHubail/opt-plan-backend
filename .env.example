# Use mongodb+srv://.../OptPlanDB if SRV DNS works on your network; otherwise use the standard URI from Atlas Connect.
DATABASE_URI=mongodb://USER:PASSWORD@host1:27017,host2:27017,host3:27017/OptPlanDB?ssl=true&replicaSet=...&authSource=admin&retryWrites=true&w=majority
PORT=5050
JWT_ACCESS_SECRET=generate-with-crypto-randomBytes
JWT_ACCESS_EXPIRES_IN=15m
CLIENT_ORIGIN=http://localhost:5173
NODE_ENV=development
