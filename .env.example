DATABASE_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/OptPlanDB
PORT=5000
JWT_ACCESS_SECRET=generate-with-crypto-randomBytes
JWT_ACCESS_EXPIRES_IN=15m
CLIENT_ORIGIN=http://localhost:5173
NODE_ENV=development
INVITE_EXPIRES_IN=168h # 7 days

# Outbound email settings (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
MAIL_FROM="Operational Plan <noreply@example.com>"

# Shown in invitation email subject/body
APP_NAME=UoB Strategic Plan Workspace